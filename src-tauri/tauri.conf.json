{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Skill 管理器",
  "version": "0.1.0",
  "identifier": "com.hakityc.skill-management",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Skill 管理器",
        "width": 1200,
        "height": 780,
        "minWidth": 820,
        "minHeight": 600,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "category": "DeveloperTool",
    "shortDescription": "管理本地 Agent Skill"
  }
}
